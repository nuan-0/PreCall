# Firebase Frontend Config (Client SDK) - Copy from firebase-applet-config.json if needed
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (Server Side) - JSON String
# In AI Studio: REMOVE THIS to completely stop server-side Firestore reads.
FIREBASE_SERVICE_ACCOUNT=

# Content Strategy
# Set to 'true' in AI Studio to use the Production API Proxy (saves reads).
# This allows viewing all 216 topics without hitting your local project quota.
VITE_USE_LOCAL_DATA=true

# Payment Gateway - Razorpay
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App Environment
NODE_ENV=development
