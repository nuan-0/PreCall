# Gemini API Key
GEMINI_API_KEY=

# Telegram Notifications (BotFather Token & UserInfo ID)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Razorpay Configuration
# Use VITE_ prefix for keys that need to be accessible in the browser
# Standard variables below (server will check all)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# VITE_RAZORPAY_KEY_ID=

# If using separate live keys (optional fallback in server logic)
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=

# Firestore Optimization
VITE_USE_LOCAL_DATA=true

# Firebase (optional, if using different service account than default)
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'
